{% if ntfy_container_labels_traefik_enabled %}
traefik.enable=true

{% if ntfy_container_labels_traefik_docker_network %}
traefik.docker.network={{ ntfy_container_labels_traefik_docker_network }}
{% endif %}

{% set middlewares = [] %}

{% if ntfy_container_labels_traefik_path_prefix != '/' %}
traefik.http.middlewares.{{ ntfy_identifier }}-slashless-redirect.redirectregex.regex=^({{ ntfy_container_labels_traefik_path_prefix | quote }})$
traefik.http.middlewares.{{ ntfy_identifier }}-slashless-redirect.redirectregex.replacement=${1}/
{% set middlewares = middlewares + [ntfy_identifier + '-slashless-redirect'] %}
{% endif %}

{% if ntfy_container_labels_traefik_path_prefix != '/' %}
traefik.http.middlewares.{{ ntfy_identifier }}-strip-prefix.stripprefix.prefixes={{ ntfy_container_labels_traefik_path_prefix }}
{% set middlewares = middlewares + [ntfy_identifier + '-strip-prefix'] %}
{% endif %}

{% if ntfy_container_labels_traefik_additional_request_headers.keys() | length > 0 %}
{% for name, value in ntfy_container_labels_traefik_additional_request_headers.items() %}
traefik.http.middlewares.{{ ntfy_identifier }}-add-request-headers.headers.customrequestheaders.{{ name }}={{ value }}
{% endfor %}
{% set middlewares = middlewares + [ntfy_identifier + '-add-request-headers'] %}
{% endif %}

{% if ntfy_container_labels_traefik_additional_response_headers.keys() | length > 0 %}
{% for name, value in ntfy_container_labels_traefik_additional_response_headers.items() %}
traefik.http.middlewares.{{ ntfy_identifier }}-add-response-headers.headers.customresponseheaders.{{ name }}={{ value }}
{% endfor %}
{% set middlewares = middlewares + [ntfy_identifier + '-add-response-headers'] %}
{% endif %}

traefik.http.routers.{{ ntfy_identifier }}.rule={{ ntfy_container_labels_traefik_rule }}
{% if ntfy_container_labels_traefik_priority | int > 0 %}
traefik.http.routers.{{ ntfy_identifier }}.priority={{ ntfy_container_labels_traefik_priority }}
{% endif %}
traefik.http.routers.{{ ntfy_identifier }}.service={{ ntfy_identifier }}
{% if middlewares | length > 0 %}
traefik.http.routers.{{ ntfy_identifier }}.middlewares={{ middlewares | join(',') }}
{% endif %}
traefik.http.routers.{{ ntfy_identifier }}.entrypoints={{ ntfy_container_labels_traefik_entrypoints }}
traefik.http.routers.{{ ntfy_identifier }}.tls={{ ntfy_container_labels_traefik_tls | to_json }}
{% if ntfy_container_labels_traefik_tls %}
traefik.http.routers.{{ ntfy_identifier }}.tls.certResolver={{ ntfy_container_labels_traefik_tls_certResolver }}
{% endif %}

traefik.http.services.{{ ntfy_identifier }}.loadbalancer.server.port={{ ntfy_container_http_port }}

{% if ntfy_container_labels_traefik_metrics_enabled %}
########################################################################
#                                                                      #
# Metrics                                                              #
#                                                                      #
########################################################################

{% set middlewares = ntfy_container_labels_traefik_metrics_middlewares %}

{% if ntfy_container_labels_traefik_metrics_middleware_basic_auth_enabled %}
traefik.http.middlewares.{{ ntfy_identifier }}-metrics-basic-auth.basicauth.users={{ ntfy_container_labels_traefik_metrics_middleware_basic_auth_users }}
{% set middlewares = middlewares + [ntfy_identifier + '-metrics-basic-auth'] %}
{% endif %}

traefik.http.middlewares.{{ ntfy_identifier }}-metrics-replace-path.replacepath.path=/metrics
{% set middlewares = middlewares + [ntfy_identifier + '-metrics-replace-path'] %}

traefik.http.routers.{{ ntfy_identifier }}-metrics.rule={{ ntfy_container_labels_traefik_metrics_rule }}

{% if ntfy_container_labels_traefik_metrics_priority | int > 0 %}
traefik.http.routers.{{ ntfy_identifier }}-metrics.priority={{ ntfy_container_labels_traefik_metrics_priority }}
{% endif %}

traefik.http.routers.{{ ntfy_identifier }}-metrics.service={{ ntfy_identifier }}-metrics

{% if middlewares | length > 0 %}
traefik.http.routers.{{ ntfy_identifier }}-metrics.middlewares={{ middlewares | join(',') }}
{% endif %}

traefik.http.routers.{{ ntfy_identifier }}-metrics.entrypoints={{ ntfy_container_labels_traefik_metrics_entrypoints }}

traefik.http.routers.{{ ntfy_identifier }}-metrics.tls={{ ntfy_container_labels_traefik_metrics_tls | to_json }}
{% if ntfy_container_labels_traefik_metrics_tls %}
traefik.http.routers.{{ ntfy_identifier }}-metrics.tls.certResolver={{ ntfy_container_labels_traefik_metrics_tls_certResolver }}
{% endif %}

traefik.http.services.{{ ntfy_identifier }}-metrics.loadbalancer.server.port={{ ntfy_container_http_port }}

########################################################################
#                                                                      #
# /Metrics                                                             #
#                                                                      #
########################################################################
{% endif %}

{% endif %}

{% for arg in ntfy_container_labels_additional_labels %}
{{ arg }}
{% endfor %}
